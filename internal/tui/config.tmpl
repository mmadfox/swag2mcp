specs:
{{- range .Specs}}
  - domain: "{{.Domain}}"
    llm_title: "{{.LLMTitle}}"
    {{- if .Instruction}}
    llm_instruction: "{{.Instruction}}"
    {{- end}}
    base_url: "{{.BaseURL}}"
    {{- if .Tags}}
    tags:
    {{- range .Tags}}
      - "{{.}}"
    {{- end}}
    {{- end}}
    {{- if and .AuthType (ne .AuthType "none")}}
    auth:
      type: "{{.AuthType}}"
      config:
      {{- range $key, $val := .AuthConfig}}
        {{$key}}: "{{$val}}"
      {{- end}}
    {{- end}}
    {{- if .Collections}}
    collections:
    {{- range .Collections}}
      - llm_title: "{{.Title}}"
        location: "{{.Location}}"
    {{- end}}
    {{- end}}
{{- end}}

